<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>io.github.legacyscreensaverfix.agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/Scripts/fix-legacyscreensaver.sh</string>
    </array>

    <key>StartInterval</key>
    <integer>30</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/fix-legacyscreensaver.out.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/fix-legacyscreensaver.err.log</string>
</dict>
</plist>
